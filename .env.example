# GROQ API
GROQ_API_KEY=your_groq_api_key_here

# LLM Configuration
DEFAULT_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
# Min delay between Groq calls (ms) — prevents 429 rate limits on free tier
LLM_REQUEST_DELAY_MS=1200
LLM_RATE_LIMIT_BACKOFF_SECONDS=3.0

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000

# FAISS (optional — off by default; keyword search only)
FAISS_INDEX_PATH=data/faiss_index
ENABLE_SEMANTIC_SEARCH=false

# Logging
LOG_LEVEL=INFO
